<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
    Full suite — all 20 tests across 10 feature domains, organised by class.
    Default suite when running plain `mvn test`.

    Retry logic: RetryListener (IAnnotationTransformer) is registered below.
    It auto-wires RetryAnalyzer onto the 6 smoke-tagged tests only (TC_AUTH_001,
    TC_SEARCH_001, TC_BOOKING_001, TC_PAYMENT_001, TC_HYBRID_001, TC_ALERT_002).
    The remaining 14 regression-only tests run without retry — failures surface
    immediately so real flakiness is not masked.
    Each failing smoke test retries up to 2 times with 1 s → 2 s back-off.

    Run: mvn test                          (defaults to chrome)
         mvn test -Dbrowser=firefox
         mvn test -Dbrowser=edge
    All test classes live in com.eventhub.tests (flat package, no sub-packages).
-->
<suite name="EventHub Full Regression Suite" verbose="1" parallel="classes" thread-count="2">

    <parameter name="browser" value="chrome"/>

    <listeners>
        <listener class-name="com.eventhub.tests.listeners.AllureListener"/>
        <listener class-name="com.eventhub.tests.listeners.TestListener"/>
        <listener class-name="com.eventhub.tests.listeners.RetryListener"/>
    </listeners>

    <test name="Authentication Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.LoginTest"/>
            <class name="com.eventhub.tests.SessionTest"/>
        </classes>
    </test>

    <test name="Search and Filtering Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.SearchFilterTest"/>
        </classes>
    </test>

    <test name="Form Validation Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.FormValidationTest"/>
        </classes>
    </test>

    <test name="Booking Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.BookingTest"/>
        </classes>
    </test>

    <test name="Payment and Pricing Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.PaymentTest"/>
        </classes>
    </test>

    <test name="Async UI Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.AsyncUITest"/>
        </classes>
    </test>

    <test name="Localization Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.LocalizationTest"/>
        </classes>
    </test>

    <test name="Hybrid API+UI Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.HybridApiUITest"/>
        </classes>
    </test>

    <test name="Alert and Interrupt Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.AlertsTest"/>
        </classes>
    </test>

    <test name="Layout and Responsive Tests">
        <groups><run><include name="regression"/></run></groups>
        <classes>
            <class name="com.eventhub.tests.LayoutsTest"/>
        </classes>
    </test>

</suite>
